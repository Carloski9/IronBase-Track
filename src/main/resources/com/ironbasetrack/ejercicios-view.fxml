<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Button?>


<VBox alignment="CENTER" spacing="20.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.ironbasetrack.ironbasetrack.controller.EjercicioController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>

    <Label text="Base de Datos: Ejercicios">
        <font>
            <Font name="System Bold" size="24.0" />
        </font>
    </Label>

    <TableView fx:id="tablaEjercicios" VBox.vgrow="ALWAYS">
        <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
        </columnResizePolicy>
        <columns>
            <TableColumn fx:id="colNombre" text="Nombre del Ejercicio" />
            <TableColumn fx:id="colGrupo" text="Grupo Muscular" />
            <TableColumn fx:id="colSubgrupo" text="Subgrupo" />
            <TableColumn fx:id="colMecanica" text="Mecánica" />
            <TableColumn fx:id="colLateralidad" text="Lateralidad" />
            <TableColumn fx:id="colMaterial" text="Material" />
        </columns>
    </TableView>

    <VBox spacing="15.0" alignment="CENTER">
        <HBox spacing="10.0" alignment="CENTER">
            <TextField fx:id="txtNombre" promptText="Nombre del Ejercicio" prefWidth="250.0" />
            <TextField fx:id="txtGrupoMuscular" promptText="Grupo Muscular" />
            <TextField fx:id="txtSubgrupoMuscular" promptText="Subgrupo" />
        </HBox>

        <HBox spacing="10.0" alignment="CENTER">
            <ComboBox fx:id="cbMecanica" promptText="Tipo Mecánica" prefWidth="150.0" />
            <ComboBox fx:id="cbLateralidad" promptText="Lateralidad" prefWidth="150.0" />
            <ComboBox fx:id="cbMaterial" promptText="Material" prefWidth="150.0" />
            <Button fx:id="btnGuardar" text="Añadir" onAction="#onGuardarClick" style="-fx-background-color: #2ecc71; -fx-text-fill: white; -fx-font-weight: bold;"/>
            <Button fx:id="btnBorrar" text="Borrar" onAction="#onBorrarClick" style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-font-weight: bold;"/>
            <Button fx:id="btnExportar" text="Exportar XML" onAction="#onExportarXMLClick" style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-font-weight: bold;"/>
        </HBox>
    </VBox>
</VBox>