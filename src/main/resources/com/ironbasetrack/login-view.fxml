<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import java.lang.String?>

<!-- CONTENEDOR RAÍZ-->
<StackPane xmlns:fx="http://javafx.com/fxml"
           fx:controller="com.ironbasetrack.ironbasetrack.controller.LoginController"
           prefWidth="400.0" prefHeight="350.0">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0"/>
    </padding>

    <!-- PANTALLA 1: PANEL DE LOGIN -->
    <VBox fx:id="panelLogin" alignment="CENTER" spacing="20.0">
        <Label text="IronBase Track - Acceso" style="-fx-font-size: 20px; -fx-font-weight: bold;"/>

        <TextField fx:id="txtEmail" promptText="Correo Electrónico" />
        <PasswordField fx:id="txtPassword" promptText="Contraseña" />

        <Button text="Iniciar Sesión" onAction="#onLoginClick" defaultButton="true"
                prefWidth="150.0" style="-fx-background-color: #2c3e50; -fx-text-fill: white; -fx-font-weight: bold;"/>

        <Hyperlink fx:id="linkRegistro" text="¿No tienes cuenta? Regístrate aquí" onAction="#mostrarPanelRegistro"/>
        <Label fx:id="lblError" textFill="RED" />
    </VBox>

    <!-- PANTALLA 2: PANEL DE REGISTRO (Oculto por defecto) -->
    <VBox fx:id="panelRegistro" visible="false" managed="false" spacing="10.0" alignment="CENTER" style="-fx-background-color: #ecf0f1; -fx-padding: 15; -fx-background-radius: 5;">
        <Label text="Crear Nueva Cuenta" style="-fx-font-weight: bold; -fx-font-size: 16px;"/>

        <TextField fx:id="txtRegNombre" promptText="Nombre" prefWidth="200.0"/>
        <TextField fx:id="txtRegApellidos" promptText="Apellidos" prefWidth="200.0"/>
        <TextField fx:id="txtRegEmail" promptText="Correo Electrónico" prefWidth="200.0"/>
        <PasswordField fx:id="txtRegPassword" promptText="Contraseña" prefWidth="200.0"/>

        <ComboBox fx:id="cbRegTipoCuenta" promptText="Tipo de Cuenta" prefWidth="200.0">
            <items>
                <javafx.collections.FXCollections fx:factory="observableArrayList">
                    <String fx:value="Atleta Gratis" />
                    <String fx:value="Atleta Pro" />
                </javafx.collections.FXCollections>
            </items>
        </ComboBox>

        <Button text="Completar Registro" onAction="#onRegistrarClick" style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-weight: bold;"/>
        <Hyperlink text="Volver al Login" onAction="#mostrarPanelLogin"/>
    </VBox>

</StackPane>