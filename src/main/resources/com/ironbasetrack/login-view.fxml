<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox alignment="CENTER" spacing="20.0" xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.ironbasetrack.ironbasetrack.controller.LoginController"
      prefWidth="400.0" prefHeight="300.0">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0"/>
    </padding>

    <Label text="IronBase Track - Acceso" style="-fx-font-size: 20px; -fx-font-weight: bold;"/>

    <TextField fx:id="txtEmail" promptText="Correo Electrónico" />
    <PasswordField fx:id="txtPassword" promptText="Contraseña" />

    <Button text="Iniciar Sesión" onAction="#onLoginClick" defaultButton="true"
            prefWidth="150.0" style="-fx-background-color: #2c3e50; -fx-text-fill: white; -fx-font-weight: bold;"/>

    <Label fx:id="lblError" textFill="RED" />
</VBox>